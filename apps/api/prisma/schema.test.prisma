// SQLite schema used only by local/CI tests. Keep models in sync with schema.prisma.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./prisma/test.db"
}

model Child {
  id              String   @id
  name            String
  age             Int
  diagnosisLabel  String?
  currentState    String?
  avatar          String?
  createdAt       DateTime @default(now())

  events     Event[]
  recordings Recording[]

  @@map("children")
}

model Event {
  id             String   @id @default(cuid())
  childId        String
  type           String
  title          String
  description    String
  timestamp      DateTime @default(now())
  sourceRole     String
  status         String   @default("confirmed")
  confidence     Float?
  rawText        String?
  linkedEventIds String?
  payload        String?

  child Child @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId])
  @@index([timestamp])
  @@index([type])
  @@map("events")
}

model Recording {
  id          String   @id @default(cuid())
  childId     String
  label       String
  durationSec Int
  timestamp   DateTime @default(now())

  child Child @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId])
  @@index([timestamp])
  @@map("recordings")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  role      String   @default("parent")
  createdAt DateTime @default(now())

  magicTokens MagicToken[]

  @@index([email])
  @@map("users")
}

model MagicToken {
  token     String   @id
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("magic_tokens")
}
