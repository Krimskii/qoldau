// SQLite schema used only by local/CI tests. Keep models in sync with schema.prisma.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./prisma/test.db"
}

model Child {
  id              String   @id
  ownerUserId     String
  name            String
  age             Int
  diagnosisLabel  String?
  currentState    String?
  avatar          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  owner      User          @relation("OwnedChildren", fields: [ownerUserId], references: [id], onDelete: Restrict)
  accessList ChildAccess[]
  invites    ChildInvite[]
  events     Event[]
  recordings Recording[]

  @@index([ownerUserId])
  @@index([ownerUserId, updatedAt])
  @@map("children")
}

model Event {
  id             String   @id @default(cuid())
  childId        String
  type           String
  title          String
  description    String
  timestamp      DateTime @default(now())
  sourceRole     String
  status         String   @default("confirmed")
  confidence     Float?
  rawText        String?
  linkedEventIds String?
  payload        String?
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  child Child @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId])
  @@index([childId, updatedAt])
  @@index([timestamp])
  @@index([type])
  @@map("events")
}

model Recording {
  id          String   @id @default(cuid())
  childId     String
  label       String
  durationSec Int
  timestamp   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  child Child @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId])
  @@index([childId, updatedAt])
  @@index([timestamp])
  @@map("recordings")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  role      String   @default("parent")
  createdAt DateTime @default(now())

  magicTokens MagicToken[]
  refreshTokens RefreshToken[]
  ownedChildren Child[]       @relation("OwnedChildren")
  childAccess   ChildAccess[]
  sentInvites    ChildInvite[] @relation("ChildInviteSender")

  @@index([email])
  @@map("users")
}

model ChildAccess {
  id        String   @id @default(cuid())
  userId    String
  childId   String
  role      String
  grantedBy String
  createdAt DateTime @default(now())
  revokedAt DateTime?

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  child Child @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@unique([userId, childId])
  @@index([userId])
  @@index([childId])
  @@map("child_access")
}

model ChildInvite {
  id         String    @id @default(cuid())
  email      String
  childId    String
  role       String
  invitedBy  String
  token      String    @unique
  createdAt  DateTime  @default(now())
  acceptedAt DateTime?
  revokedAt  DateTime?

  child   Child @relation(fields: [childId], references: [id], onDelete: Cascade)
  inviter User  @relation("ChildInviteSender", fields: [invitedBy], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([childId])
  @@map("child_invites")
}

model MagicToken {
  token     String   @id
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("magic_tokens")
}

model RefreshToken {
  token     String   @id
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}
