// Qoldau AI — Prisma schema (v1.6 P0).
//
// Production persistence uses managed PostgreSQL. For local/CI tests that do not
// have Postgres available, use prisma/schema.test.prisma with SQLite.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// Ребёнок (3 демо: Демо-профиль 1/2/3, synthetic имена v0.7.4).
model Child {
  id              String   @id
  ownerUserId     String
  name            String
  age             Int
  diagnosisLabel  String?
  currentState    String?
  avatar          String?
  createdAt       DateTime @default(now())

  owner      User          @relation("OwnedChildren", fields: [ownerUserId], references: [id], onDelete: Restrict)
  accessList ChildAccess[]
  events     Event[]
  recordings Recording[]

  @@index([ownerUserId])
  @@map("children")
}

// Событие в Event Timeline.
// Поля payload / linkedEventIds пока хранятся как JSON-строки, чтобы не менять
// API-контракты и репозиторный слой в P0. Native JSON можно вынести в P2 sync.
model Event {
  id             String   @id @default(cuid())
  childId        String
  type           String
  title          String
  description    String
  timestamp      DateTime @default(now())
  sourceRole     String
  status         String   @default("confirmed")
  confidence     Float?
  rawText        String?
  linkedEventIds String?
  payload        String?

  child Child @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId])
  @@index([timestamp])
  @@index([type])
  @@map("events")
}

// Запись голоса ребёнка (mic на /child/speak).
model Recording {
  id          String   @id @default(cuid())
  childId     String
  label       String
  durationSec Int
  timestamp   DateTime @default(now())

  child Child @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId])
  @@index([timestamp])
  @@map("recordings")
}

// Auth (v0.6.0) — magic-link flow.
//
// MagicToken: одноразовый токен с TTL. Создаётся через /api/auth/request-magic-link,
// используется в /api/auth/verify. Без email-отправки (пока не подключён SMTP/Resend).
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  role      String   @default("parent")
  createdAt DateTime @default(now())

  magicTokens MagicToken[]
  ownedChildren Child[]       @relation("OwnedChildren")
  childAccess   ChildAccess[]

  @@index([email])
  @@map("users")
}

model ChildAccess {
  id        String   @id @default(cuid())
  userId    String
  childId   String
  role      String
  grantedBy String
  createdAt DateTime @default(now())
  revokedAt DateTime?

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  child Child @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@unique([userId, childId])
  @@index([userId])
  @@index([childId])
  @@map("child_access")
}

model MagicToken {
  token     String   @id
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("magic_tokens")
}
