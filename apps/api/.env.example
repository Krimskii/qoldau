# Qoldau AI backend (v0.6.0) — environment variables

# Database — Prisma connection string
# - SQLite (default, dev): file:./prisma/dev.db
# - PostgreSQL (prod): postgresql://USER:PASS@HOST:5432/DB?schema=public
DATABASE_URL="file:./prisma/dev.db"

# Redis — опционально. Если пусто — in-memory cache.
# Пример: redis://localhost:6379
REDIS_URL=""

# Anthropic Claude (v0.6.0) — real LLM. Если пусто — mock fallback.
# Получить ключ: https://console.anthropic.com/
ANTHROPIC_API_KEY=""
# Override модели (опционально). Default: claude-3-5-haiku-20241022
ANTHROPIC_MODEL="claude-3-5-haiku-20241022"

# JWT secret для auth (v0.6.0). Сгенерируй случайную строку для прода.
JWT_SECRET=""

# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173,http://localhost:4173