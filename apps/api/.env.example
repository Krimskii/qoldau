# Qoldau AI backend (v0.6.3) — environment variables

# Database — Prisma connection string
# Production/staging must use durable PostgreSQL. If using PgBouncer, DATABASE_URL
# should be the pooled URL and DIRECT_DATABASE_URL the direct, non-pooled URL used
# by prisma migrate. If not using pooling, set both to the same Postgres URL.
DATABASE_URL="postgresql://USER:PASS@HOST:5432/DB?schema=public"
DIRECT_DATABASE_URL="postgresql://USER:PASS@HOST:5432/DB?schema=public"
# Tests use prisma/schema.test.prisma and SQLite file:./prisma/test.db.

# Redis — опционально. Если пусто — in-memory cache.
# Пример: redis://localhost:6379
REDIS_URL=""

# OpenAI (v1.0) — server-side only. One key for LLM parsing + Whisper STT.
# Never put this key in apps/prototype/.env or APK builds. If empty — mock fallback.
# Получить ключ: https://platform.openai.com/api-keys
OPENAI_API_KEY=""
# Override LLM модели (опционально). Default: gpt-4o-mini
OPENAI_LLM_MODEL="gpt-4o-mini"
OPENAI_TIMEOUT_MS=30000
OPENAI_MAX_RETRIES=2

# OpenAI Whisper (v0.6.3) — optional dedicated STT key.
# Если пусто, STT берёт OPENAI_API_KEY.
WHISPER_API_KEY=""
# Override модели (опционально). Default: whisper-1
WHISPER_MODEL="whisper-1"

# Deprecated/optional legacy Claude env. LLM parser no longer uses these.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL=""

# JWT secret для auth (v0.6.0). Сгенерируй случайную строку для прода.
JWT_SECRET=""
ACCESS_TOKEN_TTL_MS=900000
REFRESH_TOKEN_TTL_MS=2592000000

# Magic-link email delivery. In production with resend/smtp, auth request does
# not return the token. In local dev or EMAIL_PROVIDER=none, devMagicUrl is returned.
EMAIL_PROVIDER=none
APP_URL=http://localhost:5173
EMAIL_FROM="Qoldau <no-reply@qoldau.local>"
RESEND_API_KEY=""
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""

# Sentry (v0.7.3) — error tracking. Если пусто — отключено.
# Получить DSN: https://sentry.io → New Project → Copy DSN
SENTRY_DSN=""

# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173,http://localhost:4173
JSON_BODY_LIMIT_DEFAULT=256kb
JSON_BODY_LIMIT_AUDIO=35mb
MAX_TRANSCRIPT_CHARS=4000
SHUTDOWN_TIMEOUT_MS=10000
# Safety guard: keep false in production. Set true only for an intentional one-off staging/prod seed.
ALLOW_PROD_SEED=false
# Data routes (/api/children, /api/events, /api/recordings) require Bearer JWT.
# Defaults: true in production, false in local dev/demo.
REQUIRE_AUTH=true
