# Qoldau AI frontend (v0.4.0) — environment variables

# Backend API base URL. APK/prod must use HTTPS stateless proxy.
# Frontend receives only this URL; AI/STT/LLM keys stay server-side in apps/api env.
# Debug local web: http://localhost:4000
# Debug Android on LAN only: http://<computer-lan-ip>:4000
# Production Android/Wave 0: https://<prod-proxy-url>
VITE_API_BASE_URL=http://localhost:4000

# Sentry (v0.7.3) — error tracking. Если пусто — отключено.
# Должен начинаться с https://...@oN.ingest.sentry.io/...
VITE_SENTRY_DSN=
# Session Replay sample rate (0 = off, 0.1 = 10% of sessions)
VITE_SENTRY_REPLAYS_SESSION_RATE=0
VITE_SENTRY_REPLAYS_ERROR_RATE=1

# Опционально: отключить demo seed при первой загрузке (только если backend доступен)
# VITE_DISABLE_DEMO_SEED=false
